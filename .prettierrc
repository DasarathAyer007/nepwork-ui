{
  "plugins": ["@trivago/prettier-plugin-sort-imports"],

  "singleQuote": true,
  "semi": true,
  "trailingComma": "es5",

  "tabWidth": 2,
  "useTabs": false,

  "printWidth": 80,

  "arrowParens": "always",
  "bracketSpacing": true,
  "jsxSingleQuote": false,
  "bracketSameLine": true,

  "endOfLine": "lf",

  "importOrder": [
    "^react$",
    "^react-dom$",
    "<THIRD_PARTY_MODULES>",

    "^@/components/(.*)$",
    "^@/hooks/(.*)$",
    "^@/context/(.*)$",
    "^@/utils/(.*)$",
    "^@/services/(.*)$",
    "^@/assets/(.*)$",

    "^[./]"
  ],

  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
